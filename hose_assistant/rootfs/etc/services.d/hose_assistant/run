#!/usr/bin/with-contenv bashio
bashio::log.info "Starting Hose Assistant..."
export LOG_LEVEL=$(bashio::config 'log_level')
export AI_PROVIDER=$(bashio::config 'ai_provider')
export AI_API_KEY=$(bashio::config 'ai_api_key')
export AI_MODEL=$(bashio::config 'ai_model')
# The container defaults to UTC; without this every datetime.now() in the
# app (scheduling, deficits, executor) would drift from the user's local
# time by their UTC offset. Home Assistant already knows the right zone.
export TZ=$(bashio::info.timezone)
bashio::log.info "Timezone: ${TZ}"
cd /app
exec python3 -m uvicorn backend.main:app --host 0.0.0.0 --port 8099
